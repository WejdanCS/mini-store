@* @model *@
@{
    ViewData["Title"] = SharedLocalizer["Products"];
    Layout = "_DashboardLayout";
}

<div class="container">
    <h1 class="alert text-center ">@SharedLocalizer["Dashboard"]</h1>
    <hr class="my-4 w-50 mx-auto">
        <div class="card mb-3 border-0 bg-light p-3 shadow-sm">
    <form method="get" asp-action="Index" class="row g-3 align-items-end">
        <div class="col-md-9">
            <label class="form-label small fw-bold text-secondary">@SharedLocalizer["SearchByName"]</label>
            <input type="text" name="searchTerm" value="@ViewBag.CurrentSearch" placeholder="@SharedLocalizer["SearchPlaceholder"]" class="form-control" />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100 fw-bold">
                <i class="bi bi-search"></i> @SharedLocalizer["Search"]
            </button>
            <a asp-action="Index" class="btn btn-secondary">@SharedLocalizer["Cancel"]</a>
        </div>
    </form>
</div>
    @* Add Product *@
    <a asp-controller="Product" asp-action="Create" class="btn btn-primary p-2 mt-2">@SharedLocalizer["CreateProduct"]</a>
    @if (Model.Count == 0)
    {
        <h1 class=" text-center ">@SharedLocalizer["NoProducts"]</h1>
    }

    else
    {
    
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    @* <th>Image</th> *@
                    <th>#</th>
                    <th>@SharedLocalizer["ProductName"]</th>
                    <th>@SharedLocalizer["Price"]</th>
                    <th>@SharedLocalizer["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (Product product in Model)
                {
                    <tr>
                        <td>@product.Id</td>
                        @* <td><img src="~/images/@product.ImageUrl" alt="@product.Name" width="100" height="100" /></td> *@
                        <td>@product.Name</td>
                        <td>@product.Price @SharedLocalizer["Currency"]</td>

                        <td>

                            <div class="d-flex flex-row gap-2">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id"><i
                                    class="fa-solid fa-display"></i></a>
                                    <a asp-controller="Product" asp-action="Update" asp-route-id="@product.Id" class="text-info"><i
                                        class="fa-regular fa-pen-to-square"></i></a>

                                   
                                        @* <i class="fa-regular fa-trash-can text-danger"
                                           onclick="return confirm('هل تريد حذف المنتج @product.Name؟')"></i> *@
                                        <a asp-action="Delete" asp-controller="Product" asp-route-id="@product.Id"
                                           onclick="return confirm('@SharedLocalizer["DeleteConfirm"].Value')"><i
                                            class="bi bi-trash3 text-danger"></i></a>

                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>