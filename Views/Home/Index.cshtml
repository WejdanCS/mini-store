@{
    ViewData[index: "Title"] = "Home Page";
}

<div class="container">
    <h1 class="alert text-center ">الأقسام الرئيسية للمتجر </h1>
    <hr class="my-4 w-50 mx-auto">

    <div class="row d-flex justify-content-center align-items-center gap-2">
        @foreach(dynamic item in ViewBag.CategoriesList)
        {
            <dic class="col-12 col-md-6 col-lg-3">
              <div class="card text-center h-100">
                <div class="card-body">
                  <div class="mb-4">
                      <i class="fas @item.Icon text-secondary fa-2xl" ></i>
                   </div>
                    <h4 class="fw-bold mb-4">
                        @item.Name
                    </h4>
                    <a asp-action="Products" asp-route-id=@item.Id class="btn btn-primary">عرض المنتجات</a>
                </div>
              </div>
            </dic>
        }
    </div>
</div>