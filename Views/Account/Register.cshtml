@model mini_store.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "تسجيل حساب جديد";
}

@* <h1>HI FROM ASP.net</h1> *@
<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="text-center mb-4">تسجيل حساب جديد</h2>

                <form method="post" asp-action="Register">
                    @* <input type="hidden" asp-for="ReturnUrl" /> *@

                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label">الاسم الأول</label>
                        <input asp-for="FirstName" class="form-control" placeholder="أحمد"/>
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label">الاسم الأخير</label>
                        <input asp-for="LastName" class="form-control" placeholder="الحربي"/>
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">البريد الإلكتروني</label>
                        <input asp-for="Email" class="form-control" placeholder="name@example.com"/>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>


                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">كلمة المرور</label>
                        <input asp-for="Password" class="form-control" placeholder="********"/>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">تأكيد كلمة المرور</label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="********"/>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                    <div class="mb-3 form-check">
                        @* <input asp-for="RememberMe" class="form-check-input" /> *@
                        @* <label asp-for="RememberMe" class="form-check-label">تذكرني في المرة القادمة</label> *@
                    </div>
                    @* <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div> *@

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <button type="submit" class="btn btn-primary w-100">تسجيل</button>

                </form>
                <div class="text-center mt-3">
                    <p class="small mb-0">لديك حساب؟ <a asp-action="Login">تسجيل الدخول من هنا</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@* تفعيل التحقق من الأخطاء في المتصفح قبل الإرسال (Client-side validation) *@
